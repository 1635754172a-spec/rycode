# ==================== Database ====================
# SQLite database file path (relative to project root)
DATABASE_URL="file:./dev.db"

# ==================== Auth ====================
# Secret key for JWT token signing — use a long random string in production
JWT_SECRET="your-super-secret-jwt-key-change-this"

# ==================== AI Providers ====================
# Configure at least one AI provider.
# Users can also add their own API keys via the Settings page.

# Google Gemini (recommended)
GEMINI_API_KEY="your-gemini-api-key"

# OpenAI (optional)
OPENAI_API_KEY="your-openai-api-key"

# Anthropic Claude (optional)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ==================== Code Execution ====================
# Judge0 API for running user code
# Get a free key at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY="your-judge0-rapidapi-key"
JUDGE0_HOST="judge0-ce.p.rapidapi.com"

# ==================== Server ====================
PORT=3001

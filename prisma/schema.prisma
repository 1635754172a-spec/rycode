generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户认证 ====================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  username     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  settings    UserSettings?
  apiKeys     UserApiKey[]
  submissions Submission[]
  progress    UserProgress[]
}

model UserSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  theme           String   @default("dark")
  language        String   @default("zh-CN")
  defaultProvider String   @default("")  // e.g. "gemini" or "custom:minimax"
  judge0ApiKey    String   @default("")
  judge0Host      String   @default("")
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserApiKey {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // "gemini"|"openai"|"claude"|"custom:<slug>"
  encryptedKey String
  defaultModel String?
  baseUrl      String?  // for custom OpenAI-compatible providers
  customName   String?  // display name for custom providers
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ==================== 课程体系 ====================

model Textbook {
  id          String   @id @default(uuid())
  index       String
  title       String
  color       String   @default("primary")
  sourceType  String   @default("manual")
  sourceUrl   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units    Unit[]
  progress UserProgress[]
}

model Unit {
  id         String   @id @default(uuid())
  textbookId String
  title      String
  subtitle   String   @default("")
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  textbook Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id         String   @id @default(uuid())
  unitId     String
  parentId   String?  // null = top-level lesson; set = sub-lesson (3rd level)
  title      String
  content    String?  @default("")
  difficulty String   @default("MID")
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  unit        Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  parent      Lesson?    @relation("LessonChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Lesson[]   @relation("LessonChildren")
  problems    Problem[]
  progress    UserProgress[]
}

// ==================== 题目与执行 ====================

model Problem {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  description String
  difficulty  String
  starterCode String   @default("")
  testCases   String   @default("[]")
  hints       String   @default("[]")
  language    String   @default("python")
  xp          Int      @default(100)
  createdAt   DateTime @default(now())

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id               String   @id @default(uuid())
  userId           String
  problemId        String
  code             String
  language         String
  execResult       String?
  aiScore          Int?
  aiGrade          String?
  aiEfficiency     Int?
  aiReadability    Int?
  aiCorrectness    Int?
  aiCommentary     String?
  aiSuggestedCode  String?
  submittedAt      DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

// ==================== 进度追踪 ====================

model UserProgress {
  id         String   @id @default(uuid())
  userId     String
  lessonId   String
  textbookId String
  completed  Boolean  @default(false)
  bestScore  Int      @default(0)
  attempts   Int      @default(0)
  weakPoints String   @default("[]")
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  textbook Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

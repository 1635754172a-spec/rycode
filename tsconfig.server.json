{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./build/server",
    "rootDir": "./server",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
